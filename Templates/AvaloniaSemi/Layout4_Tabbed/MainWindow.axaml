<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:semi="clr-namespace:Semi.Avalonia;assembly=Semi.Avalonia"
        x:Class="Layout4_Tabbed.MainWindow"
        Title="Tabbed Layout" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundColor}">
            <TabControl>
                <TabItem Header="Tab 1" />
                <TabItem Header="Tab 2" />
                <TabItem Header="Tab 3" />
            </TabControl>
        </Border>
        <Border Grid.Row="1" Background="White" Margin="2">
            <StackPanel Margin="16">
                <TextBlock Text="MainContent" FontSize="18" FontWeight="Bold" />
                <TextBlock Text="RegionID: R2 - MainContent" Margin="0 8 0 0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>