<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Layout1_Sidebar.MainWindow"
        Title="Sidebar Layout" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2c3e50" Margin="2">
            <StackPanel>
                <TextBlock Text="Sidebar" FontSize="18" FontWeight="Bold" Margin="12 12 12 24" Foreground="White" />
                <Button Content="Home" HorizontalAlignment="Left" Margin="8" Padding="8" Background="Transparent" Foreground="White" />
                <Button Content="Settings" HorizontalAlignment="Left" Margin="8" Padding="8" Background="Transparent" Foreground="White" />
                <Button Content="Help" HorizontalAlignment="Left" Margin="8" Padding="8" Background="Transparent" Foreground="White" />
            </StackPanel>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#3498db" Margin="2">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="12">
                    <Button Content="Notifications" Padding="8" Background="Transparent" Foreground="White" />
                    <Button Content="User" Padding="8" Background="Transparent" Foreground="White" />
                </StackPanel>
            </Border>
            <Border Grid.Row="1" Background="White" Margin="2">
                <StackPanel Margin="16">
                    <TextBlock Text="MainContent" FontSize="18" FontWeight="Bold" />
                    <TextBlock Text="RegionID: R3 - MainContent" Margin="0 8 0 0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>