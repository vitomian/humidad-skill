<Window x:Class="Layout3_Hybrid.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="HumiDAD - Login" 
        Width="800" 
        Height="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{DynamicResource PrimaryHueDarkBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="100" />
                <RowDefinition Height="280" />
                <RowDefinition Height="120" />
            </Grid.RowDefinitions>
            
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="30 20" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Application" Width="40" Height="40" Foreground="White" />
                <TextBlock Text="HumiDAD" FontSize="28" FontWeight="Bold" Foreground="White" Margin="12 0 0 0" />
            </StackPanel>
            
            <Grid Grid.Row="1" Margin="40">
                <Rectangle 
                    Stroke="White" 
                    StrokeThickness="2" 
                    StrokeDashArray="5 5" 
                    RadiusX="8" 
                    RadiusY="8" 
                    Fill="Transparent" />
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                    <materialDesign:PackIcon Kind="Image" Width="64" Height="64" Foreground="White" Opacity="0.6" />
                    <TextBlock Text="登录背景图片区域" FontSize="14" Foreground="White" Margin="0 10 0 0" />
                    <TextBlock Text="请将图片放入 Images/LoginImage.jpg" FontSize="12" Foreground="LightGray" Margin="0 5 0 0" />
                </StackPanel>
            </Grid>
            
            <StackPanel Grid.Row="2" Margin="30 10">
                <TextBlock Text="专业桌面应用开发" FontSize="18" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="快速构建高质量桌面应用" FontSize="14" Foreground="LightGray" Margin="0 8 0 0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <StackPanel Margin="40" VerticalAlignment="Center">
                <TextBlock Text="欢迎使用" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueDarkBrush}" Margin="0 0 0 20" />
                
                <TextBox 
                    x:Name="txtUsername"
                    Width="280"
                    Height="45"
                    Margin="0 0 0 15"
                    materialDesign:HintAssist.Hint="请输入账号"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                    FontSize="14" />

                <PasswordBox 
                    x:Name="txtPassword"
                    Width="280"
                    Height="45"
                    Margin="0 0 0 20"
                    materialDesign:HintAssist.Hint="请输入密码"
                    PasswordChanged="txtPassword_PasswordChanged"
                    FontSize="14" />

                <Button 
                    Width="140"
                    Height="40"
                    Margin="0 0 0 20"
                    Command="{Binding LoginCommand}"
                    Content="登录系统" 
                    FontSize="14" />

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="默认账号: " FontSize="12" Foreground="Gray" />
                    <TextBlock Text="123" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                    <TextBlock Text=" / " FontSize="12" Foreground="Gray" />
                    <TextBlock Text="123" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>