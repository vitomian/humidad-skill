<Window x:Class="Layout3_Hybrid.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" Title="살북꼈애친겼" Height="600" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        
        <materialDesign:Card Grid.Column="0" Grid.RowSpan="3" Margin="4" Background="{DynamicResource PrimaryHueDarkBrush}">
            <StackPanel>
                <TextBlock Text="R6: LeftSidebar" Foreground="White" Margin="12"/>
                <Button Style="{StaticResource MaterialDesignFlatButton}" Command="{Binding NavigateCommand, CommandParameter=Home}">
                    <materialDesign:PackIcon Kind="Home"/>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Grid.Row="0" Margin="4" Background="{DynamicResource PrimaryHueLightBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="R7: TopBar"/>
                <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding RefreshCommand}">
                    <materialDesign:PackIcon Kind="Refresh"/>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Grid.Row="1" Margin="4">
            <StackPanel>
                <TextBlock Text="R8: MainContent" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="살북꼈애寮코휭혐"/>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Column="1" Grid.Row="2" Margin="4">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Info" Width="16" Height="16"/>
                <TextBlock Text="{Binding StatusText}"/>
                <TextBlock Text="R9: StatusBar" Margin="8 0 0 0" Foreground="Gray"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
