<Window x:Class="Layout5_Card.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" Title="엥튬꼈애친겼" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <materialDesign:Card Grid.Row="0" Margin="4" Background="{DynamicResource PrimaryHueDarkBrush}">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Grid3x3" Width="24" Height="24" Foreground="White" Margin="12"/>
                <TextBlock Text="R12: TopNav" Foreground="White"/>
            </StackPanel>
        </materialDesign:Card>

        <ScrollViewer Grid.Row="1" Margin="4">
            <WrapPanel>
                <materialDesign:Card Width="200" Height="150" Margin="8">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="TrendingUp" Width="32" Height="32"/>
                        <TextBlock Text="엥튬1"/>
                        <TextBlock Text="R13: CardArea" FontSize="10" Foreground="Gray"/>
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Width="200" Height="150" Margin="8">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Users" Width="32" Height="32"/>
                        <TextBlock Text="엥튬2"/>
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Width="200" Height="150" Margin="8">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Settings" Width="32" Height="32"/>
                        <TextBlock Text="엥튬3"/>
                    </StackPanel>
                </materialDesign:Card>
                <materialDesign:Card Width="200" Height="150" Margin="8">
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Bell" Width="32" Height="32"/>
                        <TextBlock Text="엥튬4"/>
                    </StackPanel>
                </materialDesign:Card>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
