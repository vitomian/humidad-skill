<Window x:Class="Layout4_Tabbed.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" Title="깃푯女꼈애친겼" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <materialDesign:Card Grid.Row="0" Margin="4" Background="{DynamicResource PrimaryHueDarkBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="R10: TabBar" Foreground="White" Margin="12"/>
                <TabControl Width="400">
                    <TabItem Header="匡도1"/>
                    <TabItem Header="匡도2"/>
                    <TabItem Header="匡도3"/>
                </TabControl>
                <Button Style="{StaticResource MaterialDesignIconButton}" Foreground="White">
                    <materialDesign:PackIcon Kind="Plus"/>
                </Button>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1" Margin="4">
            <StackPanel>
                <TextBlock Text="R11: MainContent" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="깃푯女꼈애코휭혐"/>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</Window>
